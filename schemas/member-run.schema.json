{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/member-run.schema.json",
  "title": "MemberRun",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "team_run_id", "name", "role", "provider", "status", "started_at"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "team_run_id": { "type": "string", "minLength": 1 },
    "slot_id": { "type": ["string", "null"], "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "model": { "type": ["string", "null"], "minLength": 1 },
    "provider_profile": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["provider", "execution_mode", "interaction_mode", "tool_event_fidelity", "artifact_event_fidelity", "supports_cancel", "supports_resume", "observes_native_subagents", "observes_background_tasks", "thinking_transient_only"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "execution_mode": { "type": "string", "minLength": 1 },
        "provider_version": { "type": ["string", "null"], "minLength": 1 },
        "adapter_contract_version": { "type": ["string", "null"], "minLength": 1 },
        "reviewed_provider_versions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "compatibility_status": { "type": "string", "enum": ["current", "review_required", "incompatible", "unavailable", "unknown"] },
        "adapter_reviewed_at": { "type": ["string", "null"], "minLength": 1 },
        "compatibility_note": { "type": ["string", "null"], "minLength": 1 },
        "interaction_mode": { "type": "string", "enum": ["pause_and_resume", "end_round_and_follow_up", "unsupported"] },
        "tool_event_fidelity": { "type": "string", "enum": ["none", "summary", "structured"] },
        "artifact_event_fidelity": { "type": "string", "enum": ["none", "summary", "structured"] },
        "supports_cancel": { "type": "boolean" },
        "supports_resume": { "type": "boolean" },
        "observes_native_subagents": { "type": "boolean" },
        "observes_background_tasks": { "type": "boolean" },
        "thinking_transient_only": { "type": "boolean" }
      }
    },
    "status": {
      "type": "string",
      "enum": ["starting", "idle", "queued", "running", "waiting", "reviewing", "blocked", "completed", "failed", "stopped"]
    },
    "native_session": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["provider", "execution_mode", "native_session_id", "native_locator_kind", "adapter_contract_version", "availability", "supports_resume"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "execution_mode": { "type": "string", "minLength": 1 },
        "native_session_id": { "type": "string", "minLength": 1 },
        "native_locator_kind": { "type": "string", "minLength": 1 },
        "provider_version": { "type": ["string", "null"], "minLength": 1 },
        "adapter_contract_version": { "type": "string", "minLength": 1 },
        "availability": { "type": "string", "enum": ["available", "stale", "missing", "incompatible", "unknown"] },
        "supports_resume": { "type": "boolean" },
        "last_verified_at": { "type": ["string", "null"], "minLength": 1 },
        "parent_native_session_id": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "worktree_ref": { "type": ["string", "null"], "minLength": 1 },
    "workspace_snapshot": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["cwd"],
      "properties": {
        "cwd": { "type": "string", "minLength": 1 },
        "git_head": { "type": ["string", "null"], "minLength": 1 },
        "git_branch": { "type": ["string", "null"], "minLength": 1 },
        "instruction_roots": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "skill_roots": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "owned_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "started_at": { "type": "string", "minLength": 1 },
    "last_event_at": { "type": ["string", "null"], "minLength": 1 },
    "finished_at": { "type": ["string", "null"], "minLength": 1 }
  }
}
