{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/pending-interaction.schema.json",
  "title": "PendingInteraction",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "team_run_id", "member_run_id", "provider", "provider_request_id", "method", "kind", "route", "status", "title", "prompt", "options", "created_at"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "team_run_id": { "type": "string", "minLength": 1 },
    "member_run_id": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "provider_request_id": { "type": "string", "minLength": 1 },
    "method": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["question", "tool_approval", "plan_review", "unknown"] },
    "route": { "type": "string", "enum": ["lead", "human", "policy"] },
    "status": { "type": "string", "enum": ["pending", "answered", "approved", "denied", "dismissed", "unsupported", "cancelled"] },
    "title": { "type": "string", "minLength": 1 },
    "prompt": { "type": "string", "minLength": 1 },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "intent": { "type": ["string", "null"], "minLength": 1 }
        }
      }
    },
    "tool_call_id": { "type": ["string", "null"], "minLength": 1 },
    "response_option_id": { "type": ["string", "null"], "minLength": 1 },
    "response_text": { "type": ["string", "null"] },
    "created_at": { "type": "string", "minLength": 1 },
    "resolved_at": { "type": ["string", "null"], "minLength": 1 },
    "resolved_by": { "type": ["string", "null"], "minLength": 1 }
  }
}
