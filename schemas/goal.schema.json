{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/goal.schema.json",
  "title": "Goal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "objective",
    "owner_agent_id",
    "status",
    "success_criteria",
    "priority",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "owner_agent_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["active", "blocked", "review", "done", "complete", "archived"]
    },
    "success_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "priority": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "vision_id": {
      "type": ["string", "null"]
    },
    "goal_design_id": {
      "type": ["string", "null"]
    },
    "closed_by_decision_id": {
      "type": ["string", "null"]
    },
    "git_metadata": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "repo": { "type": ["string", "null"] },
        "worktree_path": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "base_branch": { "type": ["string", "null"] },
        "pr_ref": { "type": ["string", "null"] },
        "commit": { "type": ["string", "null"] },
        "owned_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
