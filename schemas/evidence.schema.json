{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/evidence.schema.json",
  "title": "Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "source_type", "source_ref", "summary", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": ["string", "null"]
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "evidence_kind": {
      "type": ["string", "null"]
    },
    "goal_id": {
      "type": ["string", "null"]
    }
  }
}
