{
  "name": "multi-agent-harness-repo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "check": "pnpm validate:json && pnpm check:schema-fixtures && pnpm check:tool-descriptors && pnpm check:links && pnpm check:doc-size && pnpm check:skills && pnpm check:doc-governance",
    "validate:json": "node scripts/validate-json.mjs",
    "check:schema-fixtures": "node scripts/check-schema-fixtures.mjs",
    "check:tool-descriptors": "node scripts/check-tool-descriptors.mjs",
    "check:links": "node scripts/check-doc-links.mjs",
    "check:doc-size": "node scripts/check-doc-size.mjs",
    "check:skills": "node scripts/check-skills.mjs",
    "check:doc-governance": "node scripts/check-doc-governance.mjs",
    "acceptance:mvp": "node scripts/acceptance-mvp.mjs",
    "acceptance:mvp:quick": "node scripts/acceptance-mvp.mjs --skip-static",
    "acceptance:mvp:live": "node scripts/acceptance-mvp.mjs --live-codex"
  },
  "devDependencies": {
    "ajv": "8.17.1"
  }
}
