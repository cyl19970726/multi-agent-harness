{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-harness.local/schemas/company-os/work.schema.json",
  "title": "Company OS work and approval",
  "oneOf": [
    { "$ref": "#/$defs/workItem" },
    { "$ref": "#/$defs/assignment" },
    { "$ref": "#/$defs/approval" }
  ],
  "$defs": {
    "string": { "type": "string", "minLength": 1 },
    "refs": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/string" } },
    "actorType": { "enum": ["human", "agent", "external", "service"] },
    "actorRef": {
      "type": "object", "additionalProperties": false,
      "required": ["actor_type", "actor_id"],
      "properties": {
        "actor_type": { "$ref": "#/$defs/actorType" },
        "actor_id": { "$ref": "#/$defs/string" }
      }
    },
    "actors": { "type": "array", "items": { "$ref": "#/$defs/actorRef" } },
    "entityRef": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "enum": ["actor", "document", "typed_record", "business_module", "work_item", "approval", "financial_record", "evidence", "execution"] },
        "id": { "$ref": "#/$defs/string" }
      }
    },
    "executionRef": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "reference", "role_in_execution", "status", "started_at", "ended_at"],
      "properties": {
        "kind": { "enum": ["direct_human_work", "standing_agent_work", "external_engagement", "mission", "wave", "agent_team_run", "member_run", "workflow_run", "workflow_step", "host_execution"] },
        "reference": { "$ref": "#/$defs/string" },
        "role_in_execution": { "type": ["string", "null"], "minLength": 1 },
        "status": { "type": ["string", "null"], "minLength": 1 },
        "started_at": { "type": ["string", "null"], "minLength": 1 },
        "ended_at": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "workItem": {
      "type": "object", "additionalProperties": false,
      "required": [
        "id", "title", "objective", "status", "source_document_ref", "source_record_refs",
        "result_document_ref", "result_record_refs", "submitted_by", "requested_by",
        "accountable_owner", "assignees", "contributors", "reviewer", "approver",
        "execution_mode", "execution_refs", "approval_refs", "evidence_refs", "artifact_refs",
        "outcome_summary", "due_at", "priority", "risk_level", "created_at", "updated_at", "completed_at"
      ],
      "allOf": [{
        "if": { "properties": { "status": { "const": "completed" } }, "required": ["status"] },
        "then": {
          "properties": {
            "completed_at": { "$ref": "#/$defs/string" },
            "outcome_summary": { "$ref": "#/$defs/string" }
          },
          "anyOf": [
            { "properties": { "result_document_ref": { "$ref": "#/$defs/string" } } },
            { "properties": { "result_record_refs": { "type": "array", "minItems": 1 } } }
          ]
        }
      }],
      "properties": {
        "id": { "$ref": "#/$defs/string" },
        "title": { "$ref": "#/$defs/string" },
        "objective": { "$ref": "#/$defs/string" },
        "status": { "enum": ["draft", "submitted", "triaged", "accepted", "in_progress", "waiting_for_approval", "blocked", "in_review", "completed", "cancelled", "archived"] },
        "source_document_ref": { "$ref": "#/$defs/string" },
        "source_record_refs": { "$ref": "#/$defs/refs" },
        "result_document_ref": { "type": ["string", "null"], "minLength": 1 },
        "result_record_refs": { "$ref": "#/$defs/refs" },
        "submitted_by": { "$ref": "#/$defs/actorRef" },
        "requested_by": { "oneOf": [{ "$ref": "#/$defs/actorRef" }, { "type": "null" }] },
        "accountable_owner": { "$ref": "#/$defs/actorRef" },
        "assignees": { "$ref": "#/$defs/actors" },
        "contributors": { "$ref": "#/$defs/actors" },
        "reviewer": { "oneOf": [{ "$ref": "#/$defs/actorRef" }, { "type": "null" }] },
        "approver": { "oneOf": [{ "$ref": "#/$defs/actorRef" }, { "type": "null" }] },
        "execution_mode": { "enum": ["direct", "mission_wave", "agent_team", "dynamic_workflow", "host", "external", "mixed"] },
        "execution_refs": { "type": "array", "items": { "$ref": "#/$defs/executionRef" } },
        "approval_refs": { "$ref": "#/$defs/refs" },
        "evidence_refs": { "$ref": "#/$defs/refs" },
        "artifact_refs": { "$ref": "#/$defs/refs" },
        "outcome_summary": { "type": ["string", "null"], "minLength": 1 },
        "due_at": { "type": ["string", "null"], "minLength": 1 },
        "priority": { "type": ["string", "null"], "minLength": 1 },
        "risk_level": { "type": ["string", "null"], "minLength": 1 },
        "created_at": { "$ref": "#/$defs/string" },
        "updated_at": { "$ref": "#/$defs/string" },
        "completed_at": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "assignment": {
      "type": "object", "additionalProperties": false,
      "required": [
        "id", "work_item_id", "recipient", "sender", "assigned_role", "scope",
        "delivery_state", "delivery_policy_ref", "correlation_id", "delivery_evidence_ref",
        "assigned_at", "delivered_at", "acknowledged_at"
      ],
      "allOf": [
        {
          "if": { "properties": { "delivery_state": { "enum": ["delivered", "acknowledged"] } }, "required": ["delivery_state"] },
          "then": { "properties": { "delivered_at": { "$ref": "#/$defs/string" } } }
        },
        {
          "if": { "properties": { "delivery_state": { "const": "acknowledged" } }, "required": ["delivery_state"] },
          "then": { "properties": { "acknowledged_at": { "$ref": "#/$defs/string" } } }
        }
      ],
      "properties": {
        "id": { "$ref": "#/$defs/string" },
        "work_item_id": { "$ref": "#/$defs/string" },
        "recipient": { "$ref": "#/$defs/actorRef" },
        "sender": { "$ref": "#/$defs/actorRef" },
        "assigned_role": { "$ref": "#/$defs/string" },
        "scope": { "type": ["string", "null"], "minLength": 1 },
        "delivery_state": { "enum": ["pending", "delivered", "acknowledged", "declined", "failed", "cancelled"] },
        "delivery_policy_ref": { "$ref": "#/$defs/string" },
        "correlation_id": { "$ref": "#/$defs/string" },
        "delivery_evidence_ref": { "type": ["string", "null"], "minLength": 1 },
        "assigned_at": { "$ref": "#/$defs/string" },
        "delivered_at": { "type": ["string", "null"], "minLength": 1 },
        "acknowledged_at": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "approval": {
      "type": "object", "additionalProperties": false,
      "required": [
        "id", "subject_ref", "action_summary", "requested_by", "required_approver_refs",
        "required_actor_type", "policy_ref", "status", "decided_by", "decision_note",
        "evidence_refs", "requested_at", "decided_at", "expires_at"
      ],
      "allOf": [{
        "if": { "properties": { "status": { "enum": ["approved", "rejected"] } }, "required": ["status"] },
        "then": {
          "properties": {
            "decided_by": { "type": "array", "minItems": 1 },
            "decision_note": { "$ref": "#/$defs/string" },
            "decided_at": { "$ref": "#/$defs/string" }
          }
        }
      }],
      "properties": {
        "id": { "$ref": "#/$defs/string" },
        "subject_ref": { "$ref": "#/$defs/entityRef" },
        "action_summary": { "$ref": "#/$defs/string" },
        "requested_by": { "$ref": "#/$defs/actorRef" },
        "required_approver_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/actorRef" } },
        "required_actor_type": { "oneOf": [{ "$ref": "#/$defs/actorType" }, { "type": "null" }] },
        "policy_ref": { "$ref": "#/$defs/string" },
        "status": { "enum": ["requested", "approved", "rejected", "expired", "cancelled"] },
        "decided_by": { "$ref": "#/$defs/actors" },
        "decision_note": { "type": ["string", "null"], "minLength": 1 },
        "evidence_refs": { "$ref": "#/$defs/refs" },
        "requested_at": { "$ref": "#/$defs/string" },
        "decided_at": { "type": ["string", "null"], "minLength": 1 },
        "expires_at": { "type": ["string", "null"], "minLength": 1 }
      }
    }
  }
}
