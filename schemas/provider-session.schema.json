{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/provider-session.schema.json",
  "title": "ProviderSession",
  "description": "Transitional delivery/session schema. ADR 0032 replaces transcript/stdout/JSONL mirroring with a mode-aware reference to provider-native session storage.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "provider",
    "agent_member_id",
    "task_id",
    "workspace_ref",
    "provider_thread_id",
    "provider_turn_id",
    "terminal_source",
    "status",
    "command",
    "args",
    "prompt_ref",
    "prompt_summary",
    "provider_session_ref",
    "stdout_ref",
    "jsonl_ref",
    "transcript_ref",
    "last_message_ref",
    "exit_code",
    "started_at",
    "ended_at",
    "evidence_ids"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "agent_member_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": ["string", "null"]
    },
    "workspace_ref": {
      "type": ["string", "null"]
    },
    "provider_thread_id": {
      "type": ["string", "null"]
    },
    "provider_turn_id": {
      "type": ["string", "null"]
    },
    "terminal_source": {
      "type": ["string", "null"],
      "enum": [
        "turn_completed",
        "thread_idle",
        "thread_read",
        "hook_stop",
        "dry_run",
        "failed",
        "unknown",
        null
      ]
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "succeeded", "failed", "canceled", "stale"]
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "args": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prompt_ref": {
      "type": ["string", "null"]
    },
    "prompt_summary": {
      "type": ["string", "null"]
    },
    "provider_session_ref": {
      "type": ["string", "null"]
    },
    "stdout_ref": {
      "type": ["string", "null"]
    },
    "jsonl_ref": {
      "type": ["string", "null"]
    },
    "transcript_ref": {
      "type": ["string", "null"]
    },
    "last_message_ref": {
      "type": ["string", "null"]
    },
    "exit_code": {
      "type": ["integer", "null"]
    },
    "started_at": {
      "type": "string",
      "minLength": 1
    },
    "ended_at": {
      "type": ["string", "null"]
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
