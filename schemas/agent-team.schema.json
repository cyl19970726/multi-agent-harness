{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/agent-team.schema.json",
  "title": "AgentTeam",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "owner_agent_id", "member_ids", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "owner_agent_id": {
      "type": "string",
      "minLength": 1,
      "description": "Team Lead identity. The Host Agent that creates and coordinates the team is its Lead; the reserved value `host` means the current Host Agent. The Lead is not a MemberRun unless explicitly added as an executing member. The field name is retained for wire compatibility."
    },
    "status": { "type": "string", "enum": ["active", "closed", "archived"] },
    "member_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
