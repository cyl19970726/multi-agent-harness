{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/review.schema.json",
  "title": "Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "task_id",
    "goal_id",
    "reviewer_agent_id",
    "review_kind",
    "verdict",
    "summary",
    "blockers",
    "residual_risk",
    "missing_validation",
    "evidence_ids",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": ["string", "null"]
    },
    "goal_id": {
      "type": ["string", "null"]
    },
    "reviewer_agent_id": {
      "type": "string",
      "minLength": 1
    },
    "review_kind": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "residual_risk": {
      "type": ["string", "null"]
    },
    "missing_validation": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
