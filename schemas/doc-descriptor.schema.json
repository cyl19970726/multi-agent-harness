{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/doc-descriptor.schema.json",
  "title": "Doc Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "path",
    "ownerRole",
    "status",
    "lifecycle",
    "canonicalFor",
    "dependsOn",
    "machineConsumers",
    "reviewAfter",
    "lastVerifiedWith",
    "reorgTrigger"
  ],
  "properties": {
    "path": {
      "type": "string",
      "minLength": 1
    },
    "ownerRole": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["idea", "planned", "stable", "deprecated", "archival"]
    },
    "lifecycle": {
      "type": "string",
      "enum": ["volatile", "stable", "archival"]
    },
    "canonicalFor": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "machineConsumers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reviewAfter": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "lastVerifiedWith": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reorgTrigger": {
      "type": "string",
      "minLength": 1
    }
  }
}
