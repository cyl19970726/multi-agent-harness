{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/task.schema.json",
  "title": "Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "goal_id",
    "parent_task_id",
    "title",
    "objective",
    "owner_agent_id",
    "assignee_agent_id",
    "reviewer_agent_id",
    "status",
    "depends_on_task_ids",
    "workspace_ref",
    "branch_ref",
    "pr_ref",
    "owned_paths",
    "acceptance_criteria",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "goal_id": {
      "type": ["string", "null"]
    },
    "parent_task_id": {
      "type": ["string", "null"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "owner_agent_id": {
      "type": "string",
      "minLength": 1
    },
    "assignee_agent_id": {
      "type": ["string", "null"]
    },
    "reviewer_agent_id": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["planned", "assigned", "running", "blocked", "review", "done", "archived"]
    },
    "depends_on_task_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "workspace_ref": {
      "type": ["string", "null"]
    },
    "branch_ref": {
      "type": ["string", "null"]
    },
    "pr_ref": {
      "type": ["string", "null"]
    },
    "owned_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": ["string", "null"]
    },
    "scope_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requires_human_approval": {
      "type": "boolean"
    },
    "verdict_decision_id": {
      "type": ["string", "null"]
    }
  }
}
