{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/message.schema.json",
  "title": "Message",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "from_agent_id",
    "kind",
    "delivery_status",
    "content",
    "evidence_ids",
    "created_at",
    "delivery"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": ["string", "null"]
    },
    "from_agent_id": {
      "type": "string",
      "minLength": 1
    },
    "to_agent_id": {
      "type": ["string", "null"]
    },
    "channel": {
      "type": ["string", "null"]
    },
    "kind": {
      "type": "string",
      "enum": ["message", "assignment", "report"]
    },
    "delivery_status": {
      "type": "string",
      "enum": ["queued", "delivered", "acknowledged", "failed"]
    },
    "sender_kind": {
      "type": "string",
      "enum": ["agent", "operator", "system"],
      "default": "agent"
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "delivery": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "delivery_id",
        "execution_status",
        "native_session",
        "started_at",
        "provider_session_id",
        "provider_request_id",
        "provider_thread_id",
        "provider_turn_id",
        "terminal_source",
        "delivered_at",
        "last_error"
      ],
      "properties": {
        "delivery_id": { "type": ["string", "null"] },
        "execution_status": {
          "type": ["string", "null"],
          "enum": ["queued", "running", "succeeded", "failed", "canceled", "stale", null]
        },
        "native_session": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["provider", "execution_mode", "native_session_id", "native_locator_kind", "adapter_contract_version", "availability", "supports_resume"],
          "properties": {
            "provider": { "type": "string", "minLength": 1 },
            "execution_mode": { "type": "string", "minLength": 1 },
            "native_session_id": { "type": "string", "minLength": 1 },
            "native_locator_kind": { "type": "string", "minLength": 1 },
            "provider_version": { "type": ["string", "null"], "minLength": 1 },
            "adapter_contract_version": { "type": "string", "minLength": 1 },
            "availability": { "type": "string", "enum": ["available", "stale", "missing", "incompatible", "unknown"] },
            "supports_resume": { "type": "boolean" },
            "last_verified_at": { "type": ["string", "null"], "minLength": 1 },
            "parent_native_session_id": { "type": ["string", "null"], "minLength": 1 }
          }
        },
        "started_at": { "type": ["string", "null"], "minLength": 1 },
        "provider_session_id": { "type": ["string", "null"] },
        "provider_request_id": { "type": ["string", "null"] },
        "provider_thread_id": { "type": ["string", "null"] },
        "provider_turn_id": { "type": ["string", "null"] },
        "terminal_source": {
          "type": ["string", "null"],
          "enum": [
            "turn_completed",
            "thread_idle",
            "thread_read",
            "hook_stop",
            "dry_run",
            "failed",
            "unknown",
            null
          ]
        },
        "delivered_at": { "type": ["string", "null"] },
        "last_error": { "type": ["string", "null"] }
      }
    }
  }
}
