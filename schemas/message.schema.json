{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/message.schema.json",
  "title": "Message",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "from_agent_id",
    "kind",
    "content",
    "evidence_ids",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": ["string", "null"]
    },
    "from_agent_id": {
      "type": "string",
      "minLength": 1
    },
    "to_agent_id": {
      "type": ["string", "null"]
    },
    "channel": {
      "type": ["string", "null"]
    },
    "kind": {
      "type": "string",
      "enum": ["message", "task", "report"]
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
