{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/agent-member.schema.json",
  "title": "AgentMember",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "role", "capabilities", "status"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": ["idle", "busy", "paused", "stale", "retired"]
    }
  }
}
