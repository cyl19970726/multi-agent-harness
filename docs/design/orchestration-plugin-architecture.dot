digraph DynamicWorkflowArch {
  rankdir=TB;
  bgcolor="white";
  compound=true;
  fontname="Helvetica";
  labelloc="t";
  fontsize=22;
  label=<<b>Multi-Agent Harness &#8212; Dynamic Workflow Runtime (skill + CLI)</b><br/><font point-size="13" color="#475569">Any agent (Codex / Claude Code / other) authors a JSON workflow spec and runs it through a Rust runtime that orchestrates other agents.<br/>Green = exists today &#183; Blue = to build &#183; dashed grey = optional future shim.</font>>;
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=12, margin="0.18,0.10"];
  edge [fontname="Helvetica", fontsize=10, color="#334155"];

  // ================= 1. CALLER (ORCHESTRATOR) AGENT =================
  subgraph cluster_callers {
    label=<<b>1 &#183; Caller agent (the orchestrator)</b>>;
    style="rounded,filled"; fillcolor="#F8FAFC"; color="#CBD5E1"; fontsize=14;
    codex   [label=<<b>Codex</b><br/><font point-size="10">app-server, has shell access</font>>, fillcolor="#F1F5F9", color="#94A3B8"];
    claude  [label=<<b>Claude Code</b><br/><font point-size="10">exec-stream, has shell access</font>>, fillcolor="#F1F5F9", color="#94A3B8"];
    other   [label=<<b>Other agent</b><br/><font point-size="10">anything that can run a shell cmd</font>>, fillcolor="#F1F5F9", color="#94A3B8"];
  }

  // ================= 2. SKILL + CLI ENTRY =================
  subgraph cluster_entry {
    label=<<b>2 &#183; Entry  (skill + CLI &#8212; no MCP/plugin needed)</b>>;
    style="rounded,filled"; fillcolor="#EFF6FF"; color="#BFDBFE"; fontsize=14;
    skill [label=<<b>author-workflow skill</b><br/><font point-size="10">.agents/skills/author-workflow/SKILL.md<br/>teaches the agent to WRITE a valid spec + invoke the CLI + read back the run</font>>, fillcolor="#DBEAFE", color="#2563EB"];
    cli [label=<<b>harness workflow run-spec &lt;spec.json&gt;</b><br/><font point-size="10">the contract / entry point &#183; harness-cli bin<br/>(new subcommand alongside existing `workflow run --name`)</font>>, fillcolor="#DBEAFE", color="#2563EB"];
    optmcp [label=<<b>(optional, future)</b> harness-mcp shim<br/><font point-size="9">only if an agent has NO shell, or for external-project distribution;<br/>thin wrapper over the same CLI &#8212; NOT built now</font>>, fillcolor="#F8FAFC", color="#94A3B8", style="rounded,filled,dashed"];
  }

  // ================= 3. RUST RUNTIME (new crate) =================
  subgraph cluster_runtime {
    label=<<b>3 &#183; harness-workflow  (NEW Rust lib crate &#8212; extracted from harness-cli, provider-agnostic)</b>>;
    style="rounded,filled"; fillcolor="#F0FDF4"; color="#BBF7D0"; fontsize=14;

    schema [label=<<b>WorkflowSpec IR + validator</b><br/><font point-size="10">schemas/workflow-spec.schema.json<br/>WorkflowNode { Agent | Phase | Parallel | Pipeline }</font>>, fillcolor="#DBEAFE", color="#2563EB"];
    interp [label=<<b>dispatch_spec() interpreter</b><br/><font point-size="10">walks the IR; applies phase / barrier / stream semantics</font>>, fillcolor="#DBEAFE", color="#2563EB"];
    sched  [label=<<b>WorkflowScheduler</b>  (EXISTS, WP2)<br/><font point-size="10">min(16, cores-2) permits + 1000 lifetime cap &#183; workflow.rs:98</font>>, fillcolor="#DCFCE7", color="#16A34A"];
    prims  [label=<<b>primitives</b>: agent() &#183; parallel() &#183; pipeline()<br/><font point-size="10">parallel() EXISTS &#183; pipeline() to implement &#183; workflow.rs:163/229</font>>, fillcolor="#DCFCE7", color="#16A34A"];
    stepfn [label=<<b>AgentStepFn</b>  (injected trait object &#8212; the seam)<br/><font point-size="10">runtime stays provider-agnostic; the bin injects the real driver</font>>, fillcolor="#DCFCE7", color="#16A34A"];
  }

  // ================= 4. DELIVERY SEAM (stays in harness-cli) =================
  subgraph cluster_seam {
    label=<<b>4 &#183; Real driver + delivery seam  (EXISTS &#8212; harness-cli injects it into the runtime)</b>>;
    style="rounded,filled"; fillcolor="#F0FDF4"; color="#BBF7D0"; fontsize=14;
    driver [label=<<b>workflow_real_agent_step</b>  (EXISTS, main.rs:3724)<br/><font point-size="10">one agent() node &#8594; one harness Message</font>>, fillcolor="#DCFCE7", color="#16A34A"];
    claim  [label=<<b>claim_queued_message_delivery</b><br/><font point-size="10">atomic claim/lease under the store lock</font>>, fillcolor="#DCFCE7", color="#16A34A"];
    deliver[label=<<b>run_provider_delivery</b>  (main.rs:7452)<br/><font point-size="10">picks Codex or Claude adapter per node's member</font>>, fillcolor="#DCFCE7", color="#16A34A"];
  }

  // ================= 5. WORKER AGENTS =================
  subgraph cluster_workers {
    label=<<b>5 &#183; Worker agents (the orchestrated subagents &#8212; headless, fully captured)</b>>;
    style="rounded,filled"; fillcolor="#F8FAFC"; color="#CBD5E1"; fontsize=14;
    wcodex [label=<<b>Codex worker</b><br/><font point-size="10">codex exec --json / app-server turn<br/>(may spawn native multi_agent child threads)</font>>, fillcolor="#F1F5F9", color="#94A3B8"];
    wclaude[label=<<b>Claude worker</b><br/><font point-size="10">claude -p --output-format stream-json</font>>, fillcolor="#F1F5F9", color="#94A3B8"];
  }

  // ================= 6. STATE + STREAM =================
  subgraph cluster_state {
    label=<<b>6 &#183; Durable state + live stream  (EXISTS)</b>>;
    style="rounded,filled"; fillcolor="#FEFCE8"; color="#FDE68A"; fontsize=14;
    store [label=<<b>harness-store</b> (JSONL, source of truth)<br/><font point-size="10">WorkflowRun &#183; WorkflowStep &#183; ProviderSession &#183; AgentEvent<br/>(+ new: args / final_output / step.result)</font>>, fillcolor="#FEF9C3", color="#CA8A04"];
    sse   [label=<<b>SSE watcher</b>  (sse.rs)<br/><font point-size="10">tails *_runs.jsonl / *_steps.jsonl + live_turn_events</font>>, fillcolor="#FEF9C3", color="#CA8A04"];
  }

  // ================= 7. DASHBOARD =================
  subgraph cluster_ui {
    label=<<b>7 &#183; Agent Dashboard (React)</b>>;
    style="rounded,filled"; fillcolor="#F0FDF4"; color="#BBF7D0"; fontsize=14;
    surface [label=<<b>Workflows surface</b>  (EXISTS)<br/><font point-size="10">inferWorkflowShape: serial/parallel gantt &#183; AsciiGraph</font>>, fillcolor="#DCFCE7", color="#16A34A"];
    drill   [label=<<b>per-node drill-in</b><br/><font point-size="10">click node &#8594; TurnDrillIn shows that worker's streamed<br/>tool calls (component EXISTS, wire it up)</font>>, fillcolor="#DBEAFE", color="#2563EB"];
  }

  // ---------- FLOW EDGES ----------
  codex  -> skill [style=dashed, label="follows"];
  claude -> skill [style=dashed];
  other  -> skill [style=dashed];

  codex  -> cli [label=<<b>&#9312;</b> run-spec spec.json (via shell)>, color="#2563EB", penwidth=1.6];
  claude -> cli [color="#2563EB", penwidth=1.6];
  other  -> cli [color="#2563EB", penwidth=1.6];
  skill -> cli [style=dotted, label="how-to", constraint=false];
  optmcp -> cli [style=dashed, color="#94A3B8", label="future"];

  cli -> schema [label=<<b>&#9313;</b> parse + validate>, color="#2563EB", penwidth=1.6];
  schema -> interp [label=<<b>&#9314;</b> build WorkflowRun>, color="#2563EB", penwidth=1.6];
  interp -> sched [label=<<b>&#9315;</b> schedule nodes>];
  sched -> prims;
  prims -> stepfn [label="agent() node"];
  stepfn -> driver [label=<<b>&#9316;</b> injected call>, color="#16A34A", penwidth=1.6];
  driver -> claim;
  claim -> deliver;
  deliver -> wcodex [label=<<b>&#9317;</b> spawn turn>, color="#16A34A", penwidth=1.6];
  deliver -> wclaude [color="#16A34A", penwidth=1.6];

  wcodex -> store [label=<<b>&#9318;</b> events &#8594; ProviderSession / WorkflowStep>, color="#CA8A04", style=dashed];
  wclaude -> store [color="#CA8A04", style=dashed];
  interp -> store [label="WorkflowRun + final_output", color="#CA8A04", style=dashed, constraint=false];

  store -> sse [label="tail"];
  sse -> surface [label=<<b>&#9319;</b> live frames>, color="#16A34A", penwidth=1.6];
  surface -> drill [label="click node"];
  drill -> sse [style=dotted, label="live_turn_events", constraint=false];

  // return path to caller
  interp -> cli [label="result", style=dashed, color="#64748B", constraint=false];
  cli -> codex [label="stdout / run_id", style=dashed, color="#64748B", constraint=false];

  // ---------- LEGEND ----------
  subgraph cluster_legend {
    label=<<b>Legend</b>>; fontsize=12; style="rounded,filled"; fillcolor="white"; color="#E2E8F0";
    l1 [label="Exists today (reuse)", fillcolor="#DCFCE7", color="#16A34A", fontsize=10];
    l2 [label="To build", fillcolor="#DBEAFE", color="#2563EB", fontsize=10];
    l3 [label="External agent / process", fillcolor="#F1F5F9", color="#94A3B8", fontsize=10];
    l4 [label="Durable state / stream", fillcolor="#FEF9C3", color="#CA8A04", fontsize=10];
    l1 -> l2 [style=invis]; l2 -> l3 [style=invis]; l3 -> l4 [style=invis];
  }
}
