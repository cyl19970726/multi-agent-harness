{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/agent-team-run.schema.json",
  "title": "AgentTeamRun",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "host_surface",
    "objective",
    "status",
    "created_at",
    "updated_at"
  ],
  "allOf": [
    {
      "if": {
        "required": ["wave_id"],
        "properties": { "wave_id": { "type": "string" } }
      },
      "then": {
        "required": ["mission_id"],
        "properties": { "mission_id": { "type": "string" } }
      }
    }
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "definition_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "agent_team_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "previous_run_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "mission_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "wave_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "host_surface": {
      "type": "string",
      "minLength": 1
    },
    "host_thread_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "execution_root": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "planning",
        "running",
        "waiting",
        "reviewing",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "member_run_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "budget_limit_usd": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  }
}
