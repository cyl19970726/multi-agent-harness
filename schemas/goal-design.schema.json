{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/goal-design.schema.json",
  "title": "GoalDesign",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "goal_id",
    "scenario_summary",
    "non_goals",
    "risk_and_permission_boundaries",
    "required_infra",
    "agent_team",
    "task_graph",
    "evidence_plan",
    "acceptance_gates",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "goal_id": {
      "type": "string",
      "minLength": 1
    },
    "scenario_summary": {
      "type": "string",
      "minLength": 1
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk_and_permission_boundaries": {
      "type": "string",
      "minLength": 1
    },
    "required_infra": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "agent_team": {
      "type": ["string", "null"]
    },
    "task_graph": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_plan": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_gates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
